# ─── DocPilot Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ─── PostgreSQL (Aufmass DB) ──────────────────────────────────────────────────
# Option A — full connection string (preferred, overrides PG_* below)
DATABASE_URL=postgresql://docpilot:CHANGE_ME@docpilot-postgres:5432/docpilot

# Option B — individual PG_* vars (used if DATABASE_URL is not set)
PG_HOST=docpilot-postgres
PG_PORT=5432
PG_DATABASE=docpilot
PG_USER=docpilot
PG_PASSWORD=CHANGE_ME

# ─── Tenant Identity ──────────────────────────────────────────────────────────
# Single-tenant deployment: set once, never changes in production.
# Used as an application-level filter in aufmassStore queries.
# Example: TENANT_ID=geggos
TENANT_ID=geggos

# ─── AI Assistant (DoBo) ─────────────────────────────────────────────────────
AI_ENABLED=true
AI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini-2.5-pro
AI_API_KEY_ANTHROPIC=your-anthropic-api-key-here
AI_MODEL_PRO=claude-sonnet-4-20250514

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_ROOT=./storage

# ─── SMTP (email) ─────────────────────────────────────────────────────────────
SMTP_HOST=w017f912.kasserver.com
SMTP_PORT=465
SMTP_USER=m07e22c0
SMTP_PASS=
SMTP_FROM=noreply@geggos.com

# ─── NAS Sync ─────────────────────────────────────────────────────────────────
NAS_SYNC_ENABLED=false
NAS_WEBDAV_URL=
NAS_USERNAME=
NAS_PASSWORD=
NAS_SYNC_INTERVAL=300000
NAS_REMOTE_BASE=/Supreme

# ─── Performance tuning (optional) ───────────────────────────────────────────
# Log any PG query slower than this many milliseconds (default 1000)
PG_SLOW_QUERY_MS=1000
