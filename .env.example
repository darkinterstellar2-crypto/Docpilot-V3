# =============================================================================
# DocPilot-V3 — Environment Variables Example
# Copy this file to .env and fill in your values.
# =============================================================================

# ─── PostgreSQL Connection ────────────────────────────────────────────────────
# Option A: Full connection string (takes priority over individual vars below)
DATABASE_URL=postgresql://docpilot_app:your_password_here@localhost:5432/docpilot_db

# Option B: Individual connection params (used if DATABASE_URL is not set)
PG_HOST=localhost
PG_PORT=5432
PG_USER=docpilot_app
PG_PASSWORD=your_password_here
PG_DATABASE=docpilot_db

# Enable SSL for PostgreSQL (set to 'true' for managed databases like RDS, Supabase)
PG_SSL=false

# ─── Storage ──────────────────────────────────────────────────────────────────
# Override default storage root (defaults to <project-root>/storage/)
# STORAGE_ROOT=/mnt/nas/docpilot/storage

# ─── App ──────────────────────────────────────────────────────────────────────
# JWT_SECRET=your_jwt_secret_here
# PORT=3000

# ─── NAS Sync (optional) ──────────────────────────────────────────────────────
# NAS_SYNC_ENABLED=false
# NAS_URL=http://192.168.1.100
# NAS_USER=admin
# NAS_PASSWORD=nas_password_here
